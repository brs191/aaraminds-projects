# Copy to .env and adjust. All values have working defaults for `docker compose up`.

# Microsoft Teams incoming webhook. Empty = stub mode (the adapter logs the brief
# instead of posting). Paste a real webhook URL to deliver to a channel.
TEAMS_WEBHOOK_URL=

# true  = demo resumes past the approval gate automatically (end-to-end post).
# false = stops at "pending approval" — the realistic human-in-the-loop path.
AUTO_APPROVE=true

# Which board to brief, and the stale threshold in days.
BOARD_ID=1
STALE_DAYS=3
