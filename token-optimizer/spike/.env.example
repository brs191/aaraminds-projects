# Copy to .env and fill in. You only need the provider(s) your agents use.
#   cp .env.example .env

# --- Proxy auth -------------------------------------------------------------
# Any string. Agents and measure.py use this as their API key.
LITELLM_MASTER_KEY=sk-spike-local-change-me

# --- Azure OpenAI (AITO default) --------------------------------------
AZURE_API_BASE=https://YOUR-RESOURCE.openai.azure.com
AZURE_API_KEY=
AZURE_API_VERSION=2024-10-21

# --- Anthropic (for Claude Code / Claude agents) ---------------------------
ANTHROPIC_API_KEY=

# --- OpenAI (optional) ------------------------------------------------------
OPENAI_API_KEY=
